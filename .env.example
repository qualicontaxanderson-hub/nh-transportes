# =============================================================================
# ARQUITETURA NH TRANSPORTES
# =============================================================================
# O sistema usa DOIS serviços em nuvem com funções distintas:
#
#   ┌─────────────────────────────────────────────────────────────────────┐
#   │  RENDER  →  Aplicação Flask (o site, as telas, a lógica do app)     │
#   │  RAILWAY →  Banco de dados MySQL (só armazena os dados)             │
#   └─────────────────────────────────────────────────────────────────────┘
#
# REGRA SIMPLES:
#   • Variáveis do Banco (DB_*)  → configure no RENDER (para o app conectar ao Railway)
#   • Variáveis do App (SECRET_KEY, DROPBOX_*, etc.) → configure SOMENTE no RENDER
#   • No Railway: NÃO é necessário configurar nenhuma variável de ambiente do app
#
# =============================================================================


# =============================================================================
# VARIÁVEIS DO RENDER (aplicação Flask)
# Configure TODAS as variáveis abaixo no painel do Render:
# Dashboard → seu serviço → Environment → Add Environment Variable
# =============================================================================

# --- Conexão com o banco de dados MySQL (Railway) ---
DB_HOST=centerbeam.proxy.rlwy.net
DB_PORT=56026
DB_USER=root
DB_PASSWORD=sua_senha_aqui_mude_isso
DB_NAME=railway

# Configurações de Pool de Conexões (opcional)
# DB_POOL_SIZE=10              # Número máximo de conexões no pool (padrão: 10)
# DB_CONNECT_TIMEOUT=10        # Timeout de conexão em segundos (padrão: 10)

# --- Segurança ---
# Para gerar uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui_mude_isso

# --- Configurações da Aplicação ---
FLASK_DEBUG=0
PORT=5000

# --- Integração Dropbox (importação automática de OFX) ---
# Configure SOMENTE no RENDER — o Railway não precisa dessas variáveis.
#
# Como funciona:
#   Você coloca o OFX em C:\Users\ander\Dropbox\BANCOS\OFX\NOVO
#   O Dropbox sincroniza para a nuvem automaticamente
#   O Render (app Flask) baixa o arquivo direto do Dropbox via API
#   Após importar, move o arquivo para /BANCOS/OFX/IMPORTADOS no Dropbox
#
# Como gerar o DROPBOX_TOKEN:
#   1. Acesse https://www.dropbox.com/developers/apps
#   2. Clique em "Create app" → Scoped access → Full Dropbox
#   3. Na aba "Permissions", habilite: files.content.read, files.content.write, files.metadata.read
#   4. Na aba "Settings", em "OAuth 2" → "Generated access token", clique em "Generate"
#   5. Copie o token e configure como DROPBOX_TOKEN no Render (não no Railway)
#
# DROPBOX_TOKEN=token_gerado_no_dropbox_app_console
# DROPBOX_OFX_INBOX=/BANCOS/OFX/NOVO
# DROPBOX_OFX_PROCESSED=/BANCOS/OFX/IMPORTADOS


# =============================================================================
# RAILWAY (banco de dados MySQL)
# NÃO é necessário configurar nenhuma variável de ambiente adicional no Railway.
# O Railway gerencia automaticamente as variáveis internas do MySQL.
# As credenciais de conexão (DB_HOST, DB_PORT, etc.) ficam no RENDER.
# =============================================================================

