# Configurações do Banco de Dados
DB_HOST=centerbeam.proxy.rlwy.net
DB_PORT=56026
DB_USER=root
DB_PASSWORD=sua_senha_aqui_mude_isso
DB_NAME=railway

# Configurações de Pool de Conexões (opcional)
# DB_POOL_SIZE=10              # Número máximo de conexões no pool (padrão: 10)
# DB_CONNECT_TIMEOUT=10        # Timeout de conexão em segundos (padrão: 10)

# Chave Secreta da Aplicação (gere uma chave forte e única)
# Para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui_mude_isso

# Configurações da Aplicação
FLASK_DEBUG=0
PORT=5000

# Integração Dropbox API (importação automática de OFX)
# Solução ideal quando o arquivo OFX está em uma pasta Dropbox local no Windows.
# O Dropbox sincroniza o arquivo para a nuvem e o servidor baixa automaticamente.
#
# Como gerar o DROPBOX_TOKEN:
#   1. Acesse https://www.dropbox.com/developers/apps
#   2. Clique em "Create app" → Scoped access → Full Dropbox
#   3. Na aba "Permissions", habilite: files.content.read, files.content.write, files.metadata.read
#   4. Na aba "Settings", em "OAuth 2" → "Generated access token", clique em "Generate"
#   5. Copie o token e configure como variável de ambiente DROPBOX_TOKEN no Render/Railway
#
# DROPBOX_TOKEN=token_gerado_no_dropbox_app_console
# DROPBOX_OFX_INBOX=/BANCOS/OFX/NOVO
# DROPBOX_OFX_PROCESSED=/BANCOS/OFX/IMPORTADOS

