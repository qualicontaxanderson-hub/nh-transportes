# Configurações do Banco de Dados
DB_HOST=centerbeam.proxy.rlwy.net
DB_PORT=56026
DB_USER=root
DB_PASSWORD=sua_senha_aqui_mude_isso
DB_NAME=railway

# Configurações de Pool de Conexões (opcional)
# DB_POOL_SIZE=10              # Número máximo de conexões no pool (padrão: 10)
# DB_CONNECT_TIMEOUT=10        # Timeout de conexão em segundos (padrão: 10)

# Chave Secreta da Aplicação (gere uma chave forte e única)
# Para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui_mude_isso

# Configurações da Aplicação
FLASK_DEBUG=0
PORT=5000

# Pasta de entrada OFX (watch-folder)
# No Render / Railway: não precisa configurar — use o botão "Enviar OFX para Pasta" no navegador.
# Para persistência entre deploys: adicione um Disk (Render) ou Volume (Railway) em /data e configure:
#   OFX_INBOX_DIR=/data/ofx_inbox
#   OFX_PROCESSED_DIR=/data/ofx_importados
# Execução local Windows com Dropbox:
#   OFX_INBOX_DIR=C:\Users\User\Dropbox\BANCOS\OFX\NOVO
#   OFX_PROCESSED_DIR=C:\Users\User\Dropbox\BANCOS\OFX\IMPORTADOS
# Padrão (se não definido): ofx_inbox/ na raiz do projeto
# OFX_INBOX_DIR=
# OFX_PROCESSED_DIR=
